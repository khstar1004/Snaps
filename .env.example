# API 설정
API_BASE_URL=https://your-app.vercel.app/api

# OpenAI 설정
OPENAI_API_KEY=your_openai_api_key

# Supabase 설정
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Instagram OAuth
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=https://your-app.vercel.app/api/auth/instagram/callback

# 보안 설정
SECRET_KEY=your_secret_key

# 로깅 설정
LOG_LEVEL=INFO

# Thread OAuth
THREAD_CLIENT_ID=your_thread_client_id
THREAD_CLIENT_SECRET=your_thread_client_secret
THREAD_REDIRECT_URI=your_thread_redirect_uri

# Facebook/Meta 설정
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Instagram 설정
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=your_instagram_redirect_uri

# Thread 설정
THREAD_CLIENT_ID=your_thread_client_id
THREAD_CLIENT_SECRET=your_thread_client_secret
THREAD_REDIRECT_URI=your_thread_redirect_uri

# 앱 설정
BASE_URL=http://localhost:8000
ENVIRONMENT=development